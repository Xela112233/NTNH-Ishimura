<?xml version='1.0' encoding='UTF-8'?>
<Config>
  <!--
    This configuration defines custom ore generation for Minecraft 1.7.10 using the
    Custom Ore Generation (COG) mod.  The values here balance realism (approximate
    geological deposition patterns), gameplay progression and performance.  Global
    multipliers `oreFreq` and `oreSize` allow the player to adjust overall
    abundance without manually editing every entry.  Where appropriate,
    distribution sizes and frequencies are tied to these multipliers.
  -->
  <!-- ===== GLOBAL OPTIONS ===== -->
  <ConfigSection>
    <OptionDisplayGroup name="groupGeneral" displayName="General" displayState="shown">
    </OptionDisplayGroup>
    <!-- Controls overall frequency of ore deposits.  Range 0–5; default 1 -->
    <OptionNumeric name="oreFreq" default="1" min="0" max="5" displayState="shown"
      displayGroup="groupGeneral">
    </OptionNumeric>
    <!-- Controls overall size of ore deposits.  Range 0–5; default 1 -->
    <OptionNumeric name="oreSize" default="1" min="0" max="5" displayState="shown"
      displayGroup="groupGeneral">
    </OptionNumeric>
    <!-- Enables verbose debug output from COG.  Off by default -->
    <OptionChoice name="debugMode" default="false" displayState="shown_dynamic"
      displayGroup="groupGeneral">
      <Choice value="true" displayValue="On" />
      <Choice value="false" displayValue="Off" />
    </OptionChoice>
    <!-- Enables advanced options in the UI.  Off by default -->
    <OptionChoice name="advOptions" default="false" displayState="shown_dynamic"
      displayGroup="groupGeneral">
      <Choice value="true" displayValue="On" />
      <Choice value="false" displayValue="Off" />
    </OptionChoice>
  </ConfigSection>

  <!-- ===== ORE GENERATION DEFINITIONS ===== -->
  <ConfigSection>
    <!--
      Preset definitions for different types of cloud-shaped ore distributions.  Using
      presets keeps the file compact and makes it easy to adjust common parameters
      across multiple distributions.  Each preset specifies default values for
      distribution frequency, size, thickness and so on.  The `ReplacesOre` tag
      tells COG to replace vanilla stone in the world.
    -->
    <!-- Large, thin coal seams used in hills and swamps -->
    <CloudPreset name="PresetCoalSeamCloud">
      <Setting name="DistributionFrequency" avg=":= 0.012 * oreFreq" />
      <Setting name="CloudRadius" avg=":= 42 * oreSize" range=":= 10 * oreSize" />
      <Setting name="CloudThickness" avg=":= 1.3 * oreSize" range=":= 0.5 * oreSize" />
      <Setting name="CloudHeight" avg="40" range="20" type="normal" scaleTo="sealevel" />
      <Setting name="CloudInclination" avg="0.05" range="0.05" />
      <Setting name="OreDensity" avg="0.95" />
      <Setting name="OreVolumeNoiseCutoff" avg="0.1" />
      <ReplacesOre block="stone" />
    </CloudPreset>

    <!-- Small, common biome cloud.  Used for forest redstone, zinc, lead etc. -->
    <CloudPreset name="PresetBiomeCloudSmall">
      <Setting name="DistributionFrequency" avg=":= 0.008 * oreFreq" />
      <Setting name="ParentRangeLimit" avg="32" range="32" type="normal" />
      <Setting name="CloudRadius" avg=":= 16 * oreSize" range=":= 8 * oreSize" />
      <Setting name="CloudThickness" avg=":= 10 * oreSize" range=":= 4 * oreSize" />
      <Setting name="CloudSizeNoise" avg="0.2" />
      <Setting name="CloudHeight" avg="32" range="16" type="normal" scaleTo="sealevel" />
      <Setting name="CloudInclination" avg="0" range="0.25" />
      <Setting name="OreRadiusMult" avg="1" range="0.1" />
      <Setting name="OreDensity" avg="0.1" />
      <Setting name="OreVolumeNoiseCutoff" avg="0.5" />
      <ReplacesOre block="stone" />
    </CloudPreset>

    <!-- Medium-sized biome cloud.  Used for most copper, iron and savanna deposits. -->
    <CloudPreset name="PresetBiomeCloudMedium">
      <Setting name="DistributionFrequency" avg=":= 0.01 * oreFreq" />
      <Setting name="ParentRangeLimit" avg="32" range="32" type="normal" />
      <Setting name="CloudRadius" avg=":= 25 * oreSize" range=":= 10 * oreSize" />
      <Setting name="CloudThickness" avg=":= 14 * oreSize" range=":= 6 * oreSize" />
      <Setting name="CloudSizeNoise" avg="0.2" />
      <Setting name="CloudHeight" avg="32" range="16" type="normal" scaleTo="sealevel" />
      <Setting name="CloudInclination" avg="0" range="0.35" />
      <Setting name="OreRadiusMult" avg="1" range="0.1" />
      <Setting name="OreDensity" avg="0.1" />
      <Setting name="OreVolumeNoiseCutoff" avg="0.5" />
      <ReplacesOre block="stone" />
    </CloudPreset>

    <!-- Large biome cloud.  Used for large iron seams in plains and savanna. -->
    <CloudPreset name="PresetBiomeCloudLarge">
